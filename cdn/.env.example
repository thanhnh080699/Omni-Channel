PORT=8081
APP_DEBUG=true
UPLOAD_DIR=./medias
UPLOAD_PATH=/medias/
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,svg,mp4,mov,avi,webm,pdf,doc,docx,xls,xlsx,ppt,pptx,txt
MAX_UPLOAD_SIZE=10485760 # 100MB
# API Key for basic security
API_KEY=your_secret_key_here
# Base URL for serving files
BASE_URL=http://localhost:8081
GIN_MODE=debug
ALLOW_ORIGINS=*
CACHE_DIR=./medias/cache
RATE_LIMIT_RPS=5.0
RATE_LIMIT_BURST=10
REQUIRE_SIGNATURE=false
SIGNATURE_KEY=your_signature_secret_key_here
