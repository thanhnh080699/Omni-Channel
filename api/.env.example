APP_ENV=local
API_PORT=8080
MONGO_URI=mongodb://root:root@localhost:27017/omni_channel?authSource=admin
MONGO_DATABASE=omni_channel
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_TTL_HOURS=24
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
CDN_BASE_URL=http://localhost:8081
CDN_API_KEY=CHANGE_ME_CDN_API_KEY

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=redis
REDIS_DB=0
QUEUE_PARTITIONS=8

IDEMPOTENCY_TTL_HOURS=72
OUTBOUND_TTL_MINUTES=60

WHATSAPP_ADAPTER_URL=http://localhost:19090
WHATSAPP_ADAPTER_AUTOSTART=true
WHATSAPP_ADAPTER_AUTO_INSTALL=true
WHATSAPP_ADAPTER_DIR=./adapter/whatsapp
WHATSAPP_ADAPTER_COMMAND=npm
WHATSAPP_ADAPTER_ARGS=run,dev
WHATSAPP_ADAPTER_PORT=19090
WHATSAPP_SESSION_DIR=adapter/whatsapp/sessions
WEBHOOK_SHARED_SECRET=CHANGE_ME_WEBHOOK_SECRET
